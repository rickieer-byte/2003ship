# Flask
FLASK_SECRET_KEY=change-me-in-production

# MySQL (PythonAnywhere: use yourusername.mysql.pythonanywhere-services.com)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-mysql-password-here
DB_NAME=escalation_db

# Simulation — set false when using real driver GPS only
SIMULATION_MODE=true
GEOFENCE_RADIUS_KM=2.0
SIM_TICK_STALE_SECONDS=3

# Alerts (optional)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=ops@yourdomain.com
